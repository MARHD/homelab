# Copy this to .env and fill in your values
# Never commit .env to version control

TZ=Africa/Johannesburg

# Pi-hole
PIHOLE_PASSWORD=changeme

# DuckDNS
DUCKDNS_SUBDOMAIN=your-subdomain       # just the subdomain, not the full URL
DUCKDNS_TOKEN=your-duckdns-token

# WireGuard
WG_PEERS=phone,laptop,tablet           # one config QR code generated per peer

# Immich
IMMICH_DB_USER=immich
IMMICH_DB_PASS=changeme

# Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASS=changeme
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASS=changeme
NEXTCLOUD_DB_ROOT_PASS=changeme
